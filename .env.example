# Copy to .env.local and fill in.

# WSL2 + Windows filesystem: enable polling for Next.js file-watch.
# Safe to leave enabled on WSL; remove on native Linux/macOS for speed.
WATCHPACK_POLLING=true
CHOKIDAR_USEPOLLING=true

# Supabase (Prisma)
# DATABASE_URL: transaction pooler (port 6543), for app runtime
# DIRECT_URL:   session pooler (port 5432) or direct, for migrations
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-<n>-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-<n>-<region>.pooler.supabase.com:5432/postgres"

# Auth.js (fill when Task 1.4+1.5 starts)
# AUTH_SECRET=
# NEXTAUTH_URL=http://localhost:3000
