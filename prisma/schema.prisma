generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// ========== User & Auth.js v5 adapter tables ==========

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  // Custom fields (TECH_SPEC §II)
  phone         String? @unique
  wechatOpenId  String? @unique
  wechatUnionId String? @unique

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft delete for 7-day cooling-off

  accounts        Account[]
  sessions        Session[]
  profile         UserProfile?
  resumes         Resume[]
  jobDescriptions JobDescription[]

  @@index([phone])
  @@index([wechatOpenId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ========== Domain: user profile ==========

model UserProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Basic profile
  realName        String?
  city            String?
  education       String? // 本科 / 硕士 / 博士
  school          String?
  major           String?
  workYears       Int?
  currentIndustry String?
  currentRole     String?

  // Career intent
  targetIndustry    String?
  targetRole        String?
  expectedSalaryMin Int? // monthly, in CNY
  expectedSalaryMax Int?
  targetCity        String?

  // AI-inferred (internal)
  writingStyle String? // formal / casual / mixed
  skillTags    String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ========== Domain: resume ==========

model Resume {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title    String // e.g. "张三的简历"
  baseInfo Json // { name, phone, email, city, ... } — shared across versions

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  versions ResumeVersion[]

  @@index([userId])
}

model ResumeVersion {
  id       String @id @default(cuid())
  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  name      String // e.g. "应聘字节-数据分析"
  isDefault Boolean @default(false)

  // Structured content — see lib/schemas ResumeContent
  content Json

  // Template id (see Template model); not FK so templates can be pruned safely
  templateId String

  // Optional JD link
  jobDescriptionId String?
  jobDescription   JobDescription? @relation(fields: [jobDescriptionId], references: [id], onDelete: SetNull)

  // Cached match report, sourceFile URL
  matchAnalysis Json?
  sourceFileUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resumeId])
  @@index([jobDescriptionId])
}

// ========== Domain: job description ==========

model JobDescription {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  rawText String @db.Text
  parsed  Json? // { position, company, must_have, nice_to_have, ... }

  // Denormalized for quick filtering
  position String?
  company  String?
  location String?

  // Hash over (rawText) for cache lookups
  contentHash String

  createdAt DateTime @default(now())

  resumeVersions ResumeVersion[]

  @@index([userId])
  @@index([contentHash])
}

// ========== Domain: resume templates ==========

model Template {
  id          String  @id
  name        String
  description String?
  previewUrl  String?
  category    String // classic / modern / minimal
  isFree      Boolean @default(true)
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  // Font, color, layout etc.
  config Json
}
